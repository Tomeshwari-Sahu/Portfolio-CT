<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tomeshwari Sahu | Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;500;700&family=Plus+Jakarta+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #020617;
      --card: #0f172a;
      --accent: #6366f1;
      --accent-2: #2dd4bf;
      --text: #f8fafc;
      --muted: #94a3b8;
      --border: rgba(255, 255, 255, 0.08);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background-color: var(--bg);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
    }
    nav {
      position: fixed; top: 0; width: 100%;
      padding: 1.5rem 8%;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(2, 6, 23, 0.8);
      backdrop-filter: blur(15px);
      z-index: 1000;
      border-bottom: 1px solid var(--border);
    }
    .logo {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700; font-size: 1.4rem;
      background: linear-gradient(to right, var(--accent), var(--accent-2));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .nav-links { display: flex; gap: 20px; list-style: none; }
    .nav-links li {
      font-size: 0.8rem; font-weight: 700; cursor: pointer;
      color: var(--muted); transition: 0.3s; text-transform: uppercase; letter-spacing: 1px;
    }
    .nav-links li:hover, .nav-links li.active { color: var(--accent-2); }
    .page { 
      display: none; padding: 120px 8% 80px; 
      animation: pageIn 0.6s ease-out; 
    }
    .page.active { display: block; }
    @keyframes pageIn {
      from { opacity: 0; transform: translateY(15px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .hero-center { text-align: center; max-width: 800px; margin: 0 auto; }
    h1 { 
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2.5rem, 8vw, 4.5rem); 
      font-weight: 700; margin-bottom: 20px;
    }
    .gradient-text {
      background: linear-gradient(to right, var(--accent), var(--accent-2));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px; margin-top: 30px;
    }
    .card {
      background: var(--card);
      padding: 30px; border-radius: 20px;
      border: 1px solid var(--border);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .tag {
      font-size: 0.65rem; font-weight: 800;
      background: rgba(99, 102, 241, 0.1);
      padding: 5px 10px; border-radius: 5px; color: var(--accent);
      margin-right: 5px; text-transform: uppercase;
    }
    .cert-display-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 25px;
      margin-bottom: 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: 0.3s;
    }
    .cert-display-card:hover { border-color: var(--accent-2); }
    .view-btn {
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: 0.3s;
      text-decoration: none;
      font-size: 0.85rem;
      display: inline-block;
    }
    .view-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(99, 102, 241, 0.4); }
    .modal {
      display: none;
      position: fixed;
      z-index: 2000;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(2, 6, 23, 0.95);
      backdrop-filter: blur(8px);
      justify-content: center;
      align-items: center;
    }
    .modal-content {
      max-width: 85%;
      max-height: 85%;
      border-radius: 10px;
      border: 2px solid var(--border);
    }
    .close-modal {
      position: absolute;
      top: 40px; right: 40px;
      color: white; font-size: 2.5rem;
      cursor: pointer;
    }
    .edu-box { border-left: 2px solid var(--accent); padding-left: 25px; margin-left: 10px; }
    .edu-item { margin-bottom: 40px; position: relative; }
    .edu-item::before {
      content: ''; position: absolute; left: -31px; top: 5px;
      width: 10px; height: 10px; border-radius: 50%; background: var(--accent-2);
    }
    .contact-container { max-width: 600px; margin: 0 auto; text-align: center; }
    .link-pill {
      display: flex; align-items: center; justify-content: space-between;
      background: var(--card); padding: 20px 30px;
      border-radius: 100px; border: 1px solid var(--border);
      margin-bottom: 15px; text-decoration: none; color: white; transition: 0.3s;
    }
    .link-pill:hover { border-color: var(--accent-2); transform: scale(1.02); }
    footer { text-align: center; padding: 50px; color: var(--muted); font-size: 0.8rem; }
    @media (max-width: 600px) {
      .cert-display-card { flex-direction: column; text-align: center; gap: 20px; }
      .nav-links { display: none; }
    }
  </style>
</head>
